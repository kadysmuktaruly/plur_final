{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/history.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/login.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/problem",
      "dest": "api/index.py"
    },
    {
      "src": "/answer",
      "dest": "api/index.py"
    },
    {
      "src": "/leaderboard/data",
      "dest": "api/index.py"
    },
    {
      "src": "/history",
      "dest": "api/index.py"
    },
    {
      "src": "/pool/status",
      "dest": "api/index.py"
    },
    {
      "src": "/session/clear",
      "dest": "api/index.py"
    },
    {
      "src": "/history-page",
      "dest": "/public/history.html"
    },
    {
      "src": "/subscription/status",
      "dest": "api/index.py"
    },
    {
      "src": "/stripe/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/skip",
      "dest": "api/index.py"
    },
    {
      "src": "/active-session",
      "dest": "api/index.py"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "src": "/app",
      "dest": "/public/app.html"
    },
    {
      "src": "/leaderboard",
      "dest": "/public/leaderboard.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}